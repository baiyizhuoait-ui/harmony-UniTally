const zhTranslation: TranslationSet = createZhTranslation()
const enTranslation: TranslationSet = createEnTranslation()

export function getCurrentLanguage(): Language {
  const storedLang = AppStorage.get<string>('language') ?? 'zh'
  return storedLang === 'en' ? 'en' : 'zh'
}

export function setCurrentLanguage(lang: Language): void {
  AppStorage.setOrCreate<string>('language', lang)
}

export function getTranslation(lang: Language): TranslationSet {
  return lang === 'en' ? enTranslation : zhTranslation
}
